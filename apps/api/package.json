{
  "name": "api",
  "type": "module",
  "scripts": {
    "dev": "wrangler dev",
    "deploy": "wrangler deploy --minify",
    "cf-typegen": "wrangler types --env-interface CloudflareBindings",
    "db:studio": "npx drizzle-kit studio",
    "db:generate": "npx drizzle-kit generate",
    "db:push:local": "npx wrangler d1 migrations apply sigcc-manoa-db --local",
    "db:push:remote": "wrangler d1 migrations apply sigcc-manoa-db --remote",
    "secret:push": "wrangler secret put",
    "auth:bootstrap": "node ./scripts/bootstrap-user.mjs",
    "seed": "tsx ./scripts/seed-super-admin.ts"
  },
  "dependencies": {
    "@cloudflare/ai-chat": "^0.1.8",
    "@hono/zod-validator": "^0.7.6",
    "agents": "^0.7.5",
    "ai": "^6.0.111",
    "better-auth": "^1.4.5",
    "better-sqlite3": "^12.6.2",
    "dayjs": "^1.11.19",
    "drizzle-orm": "^0.45.1",
    "hono": "^4.12.0",
    "papaparse": "^5.5.3",
    "valibot": "^1.2.0",
    "workers-ai-provider": "^3.1.2",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20260124.0",
    "@types/better-sqlite3": "^7.6.13",
    "@types/papaparse": "^5.3.16",
    "drizzle-kit": "^0.31.8",
    "tsx": "^4.19.2",
    "vite-tsconfig-paths": "^6.0.5",
    "wrangler": "^4.67.0"
  }
}
